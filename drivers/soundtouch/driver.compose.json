    "onoff",
    "volume_set"
  ],
  "capabilitiesOptions": {
    "stop_playback": {
      "title": {
        "en": "Stop"
      }
    },
    "preset_1": {
      "title": {
        "en": "Preset 1"
      }
    },
    "preset_2": {
      "title": {
        "en": "Preset 2"
      }
    },
    "preset_3": {
      "title": {
        "en": "Preset 3"
      }
    },
    "preset_4": {
      "title": {
        "en": "Preset 4"
      }
    },
    "preset_5": {
      "title": {
        "en": "Preset 5"
      }
    },
    "preset_6": {
      "title": {
        "en": "Preset 6"
      }
    }
  },
  "platforms": ["local"],
  "connectivity": ["lan"],
  "discovery": "soundtouch-mdns",
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
