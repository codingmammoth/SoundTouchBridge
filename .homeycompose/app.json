{
  "id": "com.codingmammoth.homeybose",
  "version": "0.1.12",
  "compatibility": ">=5.0.0",
  "platforms": ["local"],
  "sdk": 3,
  "brandColor": "#222222",
  "name": {
    "en": "SoundTouch Bridge"
  },
  "description": {
    "en": "Local preset and stream bridge for Bose SoundTouch speakers."
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "category": "music",
  "tags": {
    "en": ["bose", "soundtouch", "radio", "music", "upnp"]
  },
  "author": {
    "name": "CodingMammoth"
  },
  "api": {
    "getPresetDevices": {
      "method": "GET",
      "path": "/preset-devices"
    },
    "searchStations": {
      "method": "POST",
      "path": "/stations/search"
    },
    "savePreset": {
      "method": "POST",
      "path": "/presets"
    },
    "updatePreset": {
      "method": "PUT",
      "path": "/presets"
    }
  }
}
