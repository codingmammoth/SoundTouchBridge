                "en": "Preset 6"
              },
              "value": "KEXP"
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Connection"
          },
          "children": [
            {
              "id": "ip_address",
              "type": "text",
              "label": {
                "en": "IP address"
              },
              "value": "",
