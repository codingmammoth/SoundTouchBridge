        "preset_5": {
          "title": {
            "en": "Preset 5"
          }
        },
        "preset_6": {
          "title": {
            "en": "Preset 6"
          }
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "discovery": "soundtouch-mdns",
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "soundtouch",
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Radio presets"
          },
          "children": [
            {
              "id": "preset_management_hint",
              "type": "label",
              "label": {
                "en": "Manage presets"
              },
              "value": "Check the SoundTouch Bridge app settings to assign or edit radio presets."
            },
            {
              "id": "preset1_summary",
              "type": "label",
              "label": {
                "en": "Preset 1"
              },
