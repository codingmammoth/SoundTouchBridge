{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.codingmammoth.homeybose",
  "version": "0.1.0",
  "compatibility": ">=5.0.0",
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "sdk": 3,
  "brandColor": "#222222",
  "name": {
    "en": "SoundTouch Bridge"
  },
  "description": {
    "en": "Local preset and stream bridge for Bose SoundTouch speakers."
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "category": "music",
  "tags": {
    "en": [
      "bose",
      "soundtouch",
      "radio",
      "music",
      "upnp"
    ]
  },
  "author": {
    "name": "CodingMammoth"
  },
  "flow": {
    "triggers": [
      {
        "id": "preset_pressed",
        "title": {
          "en": "A preset button was pressed"
        },
        "tokens": [
          {
            "name": "preset",
            "type": "number",
            "title": {
              "en": "Preset"
            }
          },
          {
            "name": "raw_event",
            "type": "string",
            "title": {
              "en": "Raw event"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=soundtouch"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "play_preset_slot",
        "title": {
          "en": "Play configured preset"
        },
        "titleFormatted": {
          "en": "Play configured preset [[preset]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=soundtouch"
          },
          {
            "name": "preset",
            "type": "dropdown",
            "title": {
              "en": "Preset"
            },
            "values": [
              {
                "id": "1",
                "label": {
                  "en": "Preset 1"
                }
              },
              {
                "id": "2",
                "label": {
                  "en": "Preset 2"
                }
              },
              {
                "id": "3",
                "label": {
                  "en": "Preset 3"
                }
              },
              {
                "id": "4",
                "label": {
                  "en": "Preset 4"
                }
              },
              {
                "id": "5",
                "label": {
                  "en": "Preset 5"
                }
              },
              {
                "id": "6",
                "label": {
                  "en": "Preset 6"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "play_stream",
        "title": {
          "en": "Play stream"
        },
        "titleFormatted": {
          "en": "Play stream [[url]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=soundtouch"
          },
          {
            "name": "url",
            "type": "text",
            "title": {
              "en": "Stream URL"
            },
            "placeholder": {
              "en": "http://example.com/stream.mp3"
            }
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "SoundTouch speaker"
      },
      "images": {
        "small": "/drivers/soundtouch/assets/images/small.png",
        "large": "/drivers/soundtouch/assets/images/large.png",
        "xlarge": "/drivers/soundtouch/assets/images/xlarge.png"
      },
      "class": "speaker",
      "capabilities": [
        "preset_1",
        "preset_2",
        "preset_3",
        "preset_4",
        "preset_5",
        "preset_6",
        "stop_playback",
        "onoff",
        "volume_set",
        "connectivity_alarm"
